# .streamlit/secrets.toml — OPTIONAL, for local development only
# NEVER commit this file. It is listed in .gitignore.
#
# This app uses BoardDocs directly for authentication — no secrets are required
# for deployment on Streamlit Community Cloud.
#
# If you want to pre-fill the username field on the login screen for convenience
# (so users only need to type their password), you may optionally set:
#
# DEFAULT_BOARDDOCS_USER = "shared-boarddocs-username"
#
# Otherwise, leave this file empty or delete it entirely.
